{
  "name": "afl-multi-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "AFL same-game multi prediction and bet tracking tool (solo/small-group).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup:local": "node scripts/setup-local.mjs",
    "check:env": "node scripts/check-env.mjs",
    "dev:safe": "node scripts/check-env.mjs && next dev",
    "backtest": "tsx scripts/backtest-sgm.ts",
    "backtest:portfolio": "tsx scripts/backtest-portfolio.ts",
    "backtest:portfolio-edge": "tsx scripts/backtest-portfolio-edge.ts",
    "settle:now": "tsx scripts/settle-now.ts",
    "test:portfolio-fill": "tsx --test src/lib/system/portfolioFill.test.ts src/lib/system/edgeScore.test.ts src/lib/system/lastGameLeaders.test.ts src/lib/system/oddsPrices.test.ts src/lib/predictions/capGoalsLine.test.ts",
    "test:odds-harvest": "tsx --test src/lib/odds/resolvePlayer.test.ts src/lib/odds/dedupe.test.ts src/lib/odds/quota.test.ts src/lib/odds/parseOutcomes.test.ts",
    "harvest:odds": "tsx scripts/harvest-odds.ts",
    "bankroll": "tsx scripts/bankroll-sim.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.5",
    "@vercel/blob": "^0.23.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "drizzle-orm": "^0.33.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
