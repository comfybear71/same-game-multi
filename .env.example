# ─────────────────────────────────────────────────────────────────────────────
# AFL Multi Tracker — environment variables
# Copy this file to `.env.local` for local development and fill in real values.
# In production these are set in the Vercel project settings (never committed).
# ─────────────────────────────────────────────────────────────────────────────

# The Odds API — PAID tier with player props enabled.
# Sport key used by the app is `aussierules_afl` (hardcoded; AFL only).
# Get/rotate your key at https://the-odds-api.com/account
ODDS_API_KEY=

# Neon Postgres connection string (pooled). Looks like:
# postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local: http://localhost:3000   Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Comma-separated allowlist of emails permitted to sign in (no open signup).
# Example: ALLOWED_EMAILS=me@example.com,mate1@example.com,mate2@example.com
ALLOWED_EMAILS=

# Vercel Blob read/write token for bet screenshot uploads.
# Create a Blob store in the Vercel dashboard; the token is generated there.
BLOB_READ_WRITE_TOKEN=

# Anthropic API key — used to read bet-slip screenshots with Claude vision.
# Optional: bet entry works manually without it; the "Read slip" button needs it.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Secret used to authorise Vercel Cron requests (optional but recommended).
# Vercel automatically sends a bearer token for cron; set this to the same value
# if you want to additionally lock the cron endpoints. Generate with openssl rand -hex 16.
CRON_SECRET=

# Contact string sent in the User-Agent header to the Squiggle API (their rule).
# IMPORTANT: use a REAL contact email. Squiggle returns 403 Forbidden for the
# placeholder below, missing, or generic user agents.
SQUIGGLE_CONTACT=AFLMultiTracker/1.0 (you@example.com)

# AFL news RSS feeds (comma-separated) for injury/late-out/travel/form context.
# Free, no API key — any AFL news site's RSS feed works (WordPress sites expose
# one at /feed/). Headlines are parsed, matched to players in a game, and a
# coarse status (out/test/managed/available) is inferred for the cards and fed
# to the suggestion engine + Claude rationale. Leave empty to disable.
# Verify each URL actually returns RSS/XML before relying on it.
AFL_NEWS_FEEDS=https://www.zerohanger.com/feed/
